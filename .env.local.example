# Sanity project config — get these from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Secret token for the Vercel revalidation webhook
# Generate with: openssl rand -hex 32
SANITY_REVALIDATION_SECRET=your_secret_here

# Optional: Sanity API token (needed for draft previews or write access)
# SANITY_API_TOKEN=your_token_here
